# Variáveis da Plataforma Embrapa I/O
# ATENÇÃO: Este arquivo é fornecido pela plataforma nos ambientes remotos
# No ambiente de desenvolvimento local, gerar usando o workflow generate-env-io
# NUNCA altere ou remova variáveis deste arquivo em ambientes remotos

# ============================================
# VARIÁVEIS OBRIGATÓRIAS (10 no total)
# ============================================

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=projeto_app_development
COMPOSE_PROFILES=development

# Servidor e Identificação
IO_SERVER=localhost
IO_PROJECT=nome-do-projeto
IO_APP=nome-da-app
IO_STAGE=development
IO_VERSION=0.25.12-dev.1
IO_DEPLOYER=nome.sobrenome@embrapa.br

# Integrações de Monitoramento
SENTRY_DSN=GET_IN_DASHBOARD
MATOMO_ID=522
MATOMO_TOKEN=

# ============================================
# NOTAS IMPORTANTES
# ============================================
# - COMPOSE_PROJECT_NAME: Deve ser ${IO_PROJECT}_${IO_APP}_${IO_STAGE}
# - COMPOSE_PROFILES: development | alpha | beta | release
# - IO_SERVER: localhost (local) ou servidor real (remoto)
# - IO_VERSION: Formato 0.YY.M-dev.X (ex: 0.25.12-dev.1 para Dez/2025)
# - IO_DEPLOYER: Email no formato nome.sobrenome@embrapa.br
# - SENTRY_DSN: Obter no Dashboard Embrapa I/O (https://dashboard.embrapa.io)
# - MATOMO_ID: Obter no Dashboard Embrapa I/O
